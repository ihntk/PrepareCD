<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.CheckMenuItem?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.RadioMenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.VBox?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="430.0"
      prefWidth="800.0" xmlns="http://javafx.com/javafx/21.0.1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.af.igor.prepcd.controller.RootLayoutController">
    <children>
        <MenuBar>
            <menus>
                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <MenuItem fx:id="renameAllDrawingsFiles" disable="true" mnemonicParsing="false"
                                  onAction="#handleRenameAllDrawingsFiles" text="Rename all drawings"/>
                        <SeparatorMenuItem mnemonicParsing="false"/>
                        <Menu mnemonicParsing="false" text="Mode">
                            <items>
                                <CheckMenuItem fx:id="generalModeMenuItem" mnemonicParsing="false"
                                               onAction="#handleGeneral" selected="true" text="General"/>
                                <CheckMenuItem fx:id="remoteModeMenuItem" mnemonicParsing="false"
                                               onAction="#handleRemote" text="Remote"/>
                                <CheckMenuItem fx:id="offlineModeMenuItem" mnemonicParsing="false"
                                               onAction="#handleOffline" text="Offline"/>
                            </items>
                        </Menu>
                        <Menu mnemonicParsing="false" text="File Manager">
                            <items>
                                <RadioMenuItem fx:id="explorerFMMenuItem" userData="EXPLORER" mnemonicParsing="false"
                                               onAction="#handleExplorer" text="Explorer">
                                    <toggleGroup>
                                        <ToggleGroup fx:id="fMGroups"/>
                                    </toggleGroup>
                                </RadioMenuItem>
                                <RadioMenuItem fx:id="doublecmdFMMenuItem" userData="DOUBLECMD" mnemonicParsing="false"
                                               onAction="#handleDoublecmd" text="Double Commander"
                                               toggleGroup="$fMGroups"/>
                                <RadioMenuItem fx:id="totalcmdFMMenuItem" userData="TOTALCMD" mnemonicParsing="false"
                                               onAction="#handleTotalcmd" text="Total Commander"
                                               toggleGroup="$fMGroups"/>
                            </items>
                        </Menu>
                        <SeparatorMenuItem mnemonicParsing="false"/>
                        <MenuItem mnemonicParsing="false" text="Close"/>
                    </items>
                </Menu>
                <Menu fx:id="openMenu" disable="true" mnemonicParsing="false" text="Open">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#handleOpenPrint" text="Print"/>
                        <MenuItem mnemonicParsing="false" onAction="#handleOpenLocalMachineDir"
                                  text="Local machine directory"/>
                        <MenuItem mnemonicParsing="false" onAction="#handleOpenRemoteMachineDir"
                                  text="Remote machine directory"/>
                        <MenuItem mnemonicParsing="false" onAction="#handleOpenBaseDrawings" text="Base drawings"/>
                        <MenuItem mnemonicParsing="false" onAction="#handleOpenBaseCD" text="Base CD"/>
                        <MenuItem mnemonicParsing="false" onAction="#handleOpenRemoteCD" text="Remote CD"/>
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Help">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#handleAbout" text="About"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </children>
</VBox>
